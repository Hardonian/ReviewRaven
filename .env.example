# ReviewRaven Environment Variables
# Copy this file to .env.local and fill in values as needed.
# All variables are optional; the app uses sensible defaults.

# NODE_ENV=production
# PORT=3000

# Rate limiting (defaults: 5 requests per 60 seconds)
# RATE_LIMIT_MAX_REQUESTS=5
# RATE_LIMIT_WINDOW_MS=60000

# Fetch timeout in milliseconds (default: 10000)
# FETCH_TIMEOUT_MS=10000

# Max response size in bytes (default: 2097152 = 2MB)
# MAX_RESPONSE_BYTES=2097152

# Circuit breaker threshold (default: 5 failures)
# CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker reset timeout in ms (default: 60000)
# CIRCUIT_BREAKER_RESET_MS=60000

# Cache TTL in milliseconds (default: 300000 = 5 min)
# CACHE_TTL_MS=300000
